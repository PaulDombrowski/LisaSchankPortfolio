---
import { getEntry } from 'astro:content';
import AboutLetterStorm from '../components/AboutLetterStorm.jsx';
import HeroMotion from '../components/HeroMotion.jsx';
import Layout from '../layouts/Layout.astro';

const home = await getEntry('pages', 'home');
---

<Layout title={home?.data.title ?? 'Lisa Schank Portfolio'} description={home?.data.intro}>
  <script is:inline>
    if (window.sessionStorage.getItem('lisa-letter-storm-played') === 'true') {
      document.documentElement.classList.add('letter-storm-played');
    }
  </script>

  <nav class="corner-nav" aria-label="Primary">
    <a class="corner top-left" href="/about/">Zur Person</a>
    <a class="corner top-right" href="/projects/">Projekte</a>
    <a class="corner bottom-left logo" href="/" aria-label="Lisa Schank home">lisa<br />schank</a>
    <button class="corner bottom-right email-link" type="button" data-email="lisaschank@web.de" aria-label="E-Mail-Adresse kopieren">@</button>
    <span class="copy-status" aria-live="polite">Kopiert in den Zwischenspeicher: lisaschank@web.de</span>
  </nav>

  <AboutLetterStorm client:load />

  <main class="home-reveal is-waiting" data-letter-reveal>
    <HeroMotion
      client:idle
      lines={home?.data.heroLines}
      marks={{
        first: home?.data.heroMark1,
        second: home?.data.heroMark2,
        third: home?.data.heroMark3,
      }}
    />
  </main>
</Layout>

<script is:inline>
  if (window.sessionStorage.getItem('lisa-letter-storm-played') === 'true') {
    document.querySelector('[data-letter-reveal]')?.classList.remove('is-waiting');
  }
</script>

<style>
  main {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
  }

  :global(.letter-storm) {
    position: fixed;
    inset: 0;
    z-index: 14;
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1), filter 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }

  :global(html.letter-storm-played .letter-storm) {
    display: none;
  }

  :global(.letter-storm canvas) {
    width: 100%;
    height: 100%;
    display: block;
  }

  :global(.letter-storm.is-done) {
    opacity: 0;
    filter: blur(10px);
  }

  .home-reveal {
    position: relative;
    opacity: 1;
    isolation: isolate;
  }

  .home-reveal.is-waiting {
    opacity: 1;
  }

  :global(.scatter-char) {
    display: inline-block;
    opacity: 1;
    filter: blur(0);
    transform: translate3d(0, 0, 0) rotate(0);
    transform-origin: 50% 78%;
    backface-visibility: hidden;
  }

  :global(.scatter-word) {
    display: inline-block;
    white-space: nowrap;
  }

  .home-reveal.is-waiting :global(.scatter-char) {
    opacity: 0;
    filter: blur(10px);
    transform: translate3d(var(--char-x), var(--char-y), 0) scale(0.88) rotate(var(--char-rotate));
  }

  .home-reveal:not(.is-waiting) :global(.scatter-char) {
    animation: letterFocusIn 1.45s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: var(--char-delay);
  }

  :global(html.letter-storm-played) .home-reveal.is-waiting :global(.scatter-char),
  :global(html.letter-storm-played) .home-reveal:not(.is-waiting) :global(.scatter-char) {
    opacity: 1;
    filter: none;
    transform: none;
    animation: none;
  }

  @keyframes letterFocusIn {
    0% {
      opacity: 0;
      filter: blur(10px);
      transform: translate3d(var(--char-x), var(--char-y), 0) scale(0.88) rotate(var(--char-rotate));
    }

    35% {
      opacity: 0.88;
      filter: blur(3px);
      transform: translate3d(calc(var(--char-x) * 0.25), calc(var(--char-y) * 0.25), 0) scale(1.02) rotate(calc(var(--char-rotate) * 0.2));
    }

    100% {
      opacity: 1;
      filter: blur(0);
      transform: translate3d(0, 0, 0) scale(1) rotate(0);
    }
  }

  .corner-nav {
    position: fixed;
    inset: 0;
    z-index: 10;
    pointer-events: none;
  }

  .corner {
    position: fixed;
    pointer-events: auto;
    color: #111513;
    font-size: clamp(1.55rem, 2.15vw, 2.1rem);
    font-weight: 600;
    line-height: 1;
    text-decoration: none;
    background: transparent;
    border: 0;
    padding: 0;
    font-family: inherit;
    transition: transform 0.25s ease, color 0.25s ease;
  }

  .corner::after {
    content: "";
    position: absolute;
    left: -5%;
    right: -5%;
    bottom: -0.18em;
    z-index: -1;
    height: 0.3em;
    border-radius: 999px;
    background: #eaff00;
    opacity: 0;
    transform: scaleX(0) skewX(-14deg);
    transform-origin: left center;
    transition: transform 0.32s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.2s ease;
  }

  .corner:hover {
    color: #0b3334;
  }

  .corner:hover::after {
    opacity: 0.9;
    transform: scaleX(1) skewX(-7deg);
  }

  .top-left {
    top: 10px;
    left: 10px;
  }

  .top-left:hover {
    transform: translateY(-2px);
  }

  .top-right {
    top: 10px;
    right: 10px;
  }

  .top-right:hover {
    transform: translateY(-2px);
  }

  .bottom-left {
    bottom: 10px;
    left: 10px;
  }

  .bottom-right {
    right: 10px;
    bottom: 10px;
  }

  .bottom-right:hover {
    transform: translateY(-2px);
  }

  .logo {
    font-size: clamp(1.05rem, 1.8vw, 1.6rem);
    line-height: 0.88;
    transform: rotate(-7deg);
    text-transform: lowercase;
  }

  .logo:hover {
    transform: rotate(-7deg) translateY(-2px);
  }

  .email-link {
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 0.8;
    cursor: pointer;
  }

  .copy-status {
    position: fixed;
    right: 10px;
    bottom: 64px;
    z-index: 10;
    color: #111513;
    max-width: min(520px, calc(100% - 24px));
    font-size: clamp(1.45rem, 3vw, 2.45rem);
    font-weight: 700;
    text-align: right;
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .copy-status.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  :global(.hero-motion) {
    position: relative;
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 92px 0;
    isolation: isolate;
  }

  :global(.mouse-gradient) {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 22rem 13rem at var(--glow-x) var(--glow-y), rgba(0, 217, 255, 0.42), transparent 62%),
      radial-gradient(ellipse 16rem 24rem at calc(var(--glow-x) + 8%) calc(var(--glow-y) - 6%), rgba(255, 79, 139, 0.31), transparent 64%),
      radial-gradient(ellipse 18rem 10rem at calc(var(--glow-x) - 7%) calc(var(--glow-y) + 9%), rgba(234, 255, 0, 0.26), transparent 66%);
    filter: blur(18px) saturate(1.35);
    opacity: 0.78;
    mix-blend-mode: multiply;
    transform: translateZ(0);
  }

  @media (hover: none), (pointer: coarse) {
    :global(.mouse-gradient) {
      background:
        radial-gradient(ellipse 19rem 12rem at 28% 38%, rgba(0, 217, 255, 0.38), transparent 62%),
        radial-gradient(ellipse 15rem 22rem at 68% 44%, rgba(255, 79, 139, 0.28), transparent 64%),
        radial-gradient(ellipse 17rem 10rem at 48% 64%, rgba(234, 255, 0, 0.24), transparent 66%);
      animation: mobileGlow 13s ease-in-out infinite alternate;
      opacity: 0.72;
    }
  }

  @keyframes mobileGlow {
    0% {
      transform: translate3d(-4%, -2%, 0) scale(1);
    }

    50% {
      transform: translate3d(3%, 2%, 0) scale(1.08);
    }

    100% {
      transform: translate3d(1%, -3%, 0) scale(0.98);
    }
  }

  .eyebrow {
    margin: 0 0 16px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #315b56;
  }

  h1,
  p {
    overflow-wrap: anywhere;
  }

  :global(.statement) {
    position: relative;
    z-index: 1;
    width: min(1040px, 100%);
    margin: 0;
    color: #111513;
    font-size: clamp(2.1rem, 4vw, 4.2rem);
    font-weight: 500;
    line-height: 1.32;
    letter-spacing: 0;
    text-align: center;
  }

  :global(.statement > span) {
    display: block;
  }

  :global(.marked) {
    position: relative;
    display: inline-block;
    margin-inline: 0.18em;
    white-space: nowrap;
  }

  :global(.portrait-trigger) {
    position: relative;
    display: inline-block;
    font-weight: 700;
    outline: none;
    cursor: default;
  }

  :global(.portrait-trigger::after) {
    content: "";
    position: absolute;
    left: -4%;
    right: -4%;
    bottom: -0.08em;
    z-index: -1;
    height: 0.22em;
    border-radius: 999px;
    background: rgba(0, 217, 255, 0.46);
    opacity: 0;
    transform: scaleX(0.72) skewX(-10deg);
    transition: opacity 0.25s ease, transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  :global(.portrait-trigger:hover::after),
  :global(.portrait-trigger:focus-visible::after) {
    opacity: 1;
    transform: scaleX(1) skewX(-10deg);
  }

  :global(.portrait-card) {
    position: fixed;
    left: 50%;
    top: 50%;
    z-index: 8;
    width: clamp(280px, 30vw, 470px);
    aspect-ratio: 4 / 5;
    border-radius: 8px;
    overflow: hidden;
    pointer-events: none;
    transform-origin: 50% 100%;
    box-shadow: 0 24px 70px rgba(17, 21, 19, 0.22);
  }

  :global(.portrait-card img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
  }

  :global(.marker) {
    position: absolute;
    left: -4%;
    width: 108%;
    pointer-events: none;
  }

  :global(.marker-sketch) {
    bottom: -0.15em;
    z-index: -1;
    height: 0.52em;
    overflow: visible;
    filter: drop-shadow(0 0 8px rgba(0, 217, 255, 0.34));
  }

  :global(.marker-circle-sketch) {
    left: -12%;
    bottom: -0.32em;
    z-index: -1;
    width: 124%;
    height: 1.5em;
    overflow: visible;
    filter: drop-shadow(0 0 10px rgba(255, 79, 139, 0.32));
  }

  :global(.small-note) {
    position: absolute;
    left: 50%;
    bottom: 15vh;
    width: min(620px, calc(100% - 40px));
    margin: 0;
    color: rgba(17, 21, 19, 0.54);
    font-size: 0.95rem;
    line-height: 1.5;
    text-align: center;
  }

  @media (max-width: 700px) {
    main {
      width: min(100% - 28px, 1120px);
    }

    :global(.hero-motion) {
      min-height: 100svh;
      padding: 72px 0;
    }

    .corner {
      font-size: 1.24rem;
    }

    :global(.statement) {
      font-size: clamp(1.85rem, 9.4vw, 3.05rem);
      line-height: 1.2;
    }

    :global(.marked) {
      white-space: normal;
      margin-inline: 0.08em;
    }

    :global(.portrait-card) {
      display: none;
    }

    :global(.marker-sketch) {
      bottom: -0.08em;
      height: 0.42em;
    }

    :global(.marker-circle-sketch) {
      bottom: -0.18em;
      height: 1.28em;
    }
  }
</style>

<script>
  function bindCopyEmail() {
    const button = document.querySelector('[data-email]');
    const status = document.querySelector('.copy-status');
    if (!button || !status) return;

    button.addEventListener('click', async () => {
      const email = button.getAttribute('data-email');
      if (!email) return;

      try {
        await navigator.clipboard.writeText(email);
      } catch {
        window.location.href = `mailto:${email}`;
        return;
      }

      status.classList.add('is-visible');
      window.clearTimeout(window.__copyEmailTimeout);
      window.__copyEmailTimeout = window.setTimeout(() => {
        status.classList.remove('is-visible');
      }, 3200);
    });
  }

  bindCopyEmail();
  document.addEventListener('astro:page-load', bindCopyEmail);

</script>
