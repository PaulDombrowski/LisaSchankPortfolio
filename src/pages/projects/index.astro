---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../lib/paths.js';

const projects = (await getCollection('projects')).sort((a, b) => {
  return (a.data.order ?? 0) - (b.data.order ?? 0);
});
---

<Layout title="Projekte | Lisa Schank Portfolio">
  <nav class="corner-nav" aria-label="Primary">
    <a class="corner top-left" href={withBase('/')}>Start</a>
    <a class="corner top-right" href={withBase('/about/')}>Zur Person</a>
    <a class="corner bottom-left logo" href={withBase('/')} aria-label="Lisa Schank home">lisa<br />schank</a>
  </nav>

  <main class="page-shell page-reveal">
    <p class="kicker">Projekte</p>
    <h1>Ausgewählte Arbeiten<span class="headline-marker" aria-hidden="true"></span></h1>

    <div class="project-list">
      {projects.map((project) => (
        <a class="project" href={withBase(`/projects/${project.id}/`)}>
          <span class="project-index">{String(project.data.order ?? 0).padStart(2, '0')}</span>
          <span class="project-title">{project.data.title}</span>
          <span class="project-meta">
            {project.data.year && <span>{project.data.year}</span>}
            {project.data.medium && <span>{project.data.medium}</span>}
          </span>
          <img src={withBase(project.data.cover ?? '/uploads/placeholder.svg')} alt={project.data.coverAlt ?? ''} />
        </a>
      ))}
    </div>
  </main>
</Layout>

<style>
  .corner-nav {
    position: fixed;
    inset: 0;
    z-index: 10;
    pointer-events: none;
  }

  .corner {
    position: fixed;
    pointer-events: auto;
    color: #111513;
    font-size: clamp(1.55rem, 2.15vw, 2.1rem);
    font-weight: 600;
    line-height: 1;
    text-decoration: none;
    transition: transform 0.25s ease, color 0.25s ease;
  }

  .corner:hover {
    color: #0b3334;
  }

  .top-left {
    top: 10px;
    left: 10px;
  }

  .top-left:hover {
    transform: translateY(-2px);
  }

  .top-right {
    top: 10px;
    right: 10px;
  }

  .top-right:hover {
    transform: translateY(-2px);
  }

  .bottom-left {
    bottom: 10px;
    left: 10px;
  }

  .logo {
    font-size: clamp(1.05rem, 1.8vw, 1.6rem);
    line-height: 0.88;
    transform: rotate(-7deg);
    text-transform: lowercase;
  }

  .logo:hover {
    transform: rotate(-10deg) translateY(-2px);
  }

  .page-shell {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 18vh 0 16vh;
  }

  .page-reveal {
    animation: pageReveal 1.05s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .kicker {
    margin: 0 0 18px;
    color: #315b56;
    font-weight: 700;
    text-transform: uppercase;
  }

  h1 {
    position: relative;
    display: inline-block;
    margin: 0 0 70px;
    font-size: clamp(3.2rem, 9vw, 7.2rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: 0;
  }

  .headline-marker {
    position: absolute;
    left: 8%;
    bottom: -0.08em;
    z-index: -1;
    width: 86%;
    height: 0.24em;
    border-radius: 999px;
    background: #eaff00;
    filter: drop-shadow(0 0 8px rgba(234, 255, 0, 0.34));
    transform-origin: left center;
    animation: drawMarker 0.85s 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .project-list {
    display: grid;
    gap: 0;
    border-top: 1px solid rgba(18, 21, 19, 0.18);
  }

  .project {
    position: relative;
    display: grid;
    grid-template-columns: 64px 1fr auto;
    gap: 24px;
    align-items: center;
    min-height: 92px;
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid rgba(18, 21, 19, 0.18);
    animation: itemReveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .project:nth-child(1) {
    animation-delay: 0.5s;
  }

  .project:nth-child(2) {
    animation-delay: 0.58s;
  }

  .project:nth-child(3) {
    animation-delay: 0.66s;
  }

  .project:nth-child(n + 4) {
    animation-delay: 0.74s;
  }

  .project::before {
    content: "";
    position: absolute;
    inset: 18px -8px;
    z-index: -1;
    border-radius: 8px;
    background: rgba(0, 217, 255, 0.16);
    opacity: 0;
    transform: scaleX(0.96);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .project:hover::before {
    opacity: 1;
    transform: scaleX(1);
  }

  .project-index {
    color: #315b56;
    font-weight: 700;
  }

  .project-title {
    font-size: clamp(1.6rem, 4vw, 3.7rem);
    font-weight: 500;
    line-height: 1;
  }

  .project-meta {
    display: flex;
    gap: 10px;
    color: #4c514c;
    white-space: nowrap;
  }

  .project img {
    position: fixed;
    right: 32px;
    bottom: 72px;
    z-index: 20;
    width: min(300px, 24vw);
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border: 1px solid rgba(18, 21, 19, 0.18);
    opacity: 0;
    pointer-events: none;
    transform: translateY(12px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .project:hover img {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 700px) {
    .corner {
      font-size: 1.24rem;
    }

    .page-shell {
      padding-top: 18vh;
    }

    .project {
      grid-template-columns: 42px 1fr;
      gap: 14px;
      padding: 20px 0;
    }

    .project-meta {
      grid-column: 2;
      white-space: normal;
    }

    .project img {
      display: none;
    }
  }

  @keyframes pageReveal {
    from {
      opacity: 0;
      filter: blur(16px) contrast(1.25);
      transform: scale(1.01);
    }

    to {
      opacity: 1;
      filter: blur(0) contrast(1);
      transform: scale(1);
    }
  }

  @keyframes drawMarker {
    from {
      opacity: 0;
      transform: scaleX(0) skewX(-16deg);
    }

    to {
      opacity: 1;
      transform: scaleX(1) skewX(-10deg);
    }
  }

  @keyframes itemReveal {
    from {
      opacity: 0;
      filter: blur(8px);
      transform: translateY(18px);
    }

    to {
      opacity: 1;
      filter: blur(0);
      transform: translateY(0);
    }
  }
</style>
