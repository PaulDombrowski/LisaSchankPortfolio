---
import { getEntry, render } from 'astro:content';
import AboutNameFall from '../components/AboutNameFall.jsx';
import Layout from '../layouts/Layout.astro';

const about = await getEntry('pages', 'about');
const { Content } = about ? await render(about) : { Content: null };
---

<Layout title="Zur Person | Lisa Schank Portfolio" description={about?.data.intro}>
  <nav class="corner-nav" aria-label="Primary">
    <a class="corner top-left" href="/">Start</a>
    <a class="corner top-right" href="/projects/">Projekte</a>
    <a class="corner bottom-left logo" href="/" aria-label="Lisa Schank home">lisa<br />schank</a>
  </nav>

  <div class="about-gradient" aria-hidden="true"></div>
  <AboutNameFall client:idle />

  <main class="page-shell" data-about-page>
    <p class="kicker reveal-section" style="--reveal-delay: 0.05s;">Zur Person</p>
    <div class="name-stage reveal-section" style="--reveal-delay: 0.18s;">
      <h1>Lisa Schank</h1>
      <span class="headline-marker" aria-hidden="true"></span>
    </div>
    {about?.data.intro && <p class="intro reveal-section" style="--reveal-delay: 0.34s;">{about.data.intro}</p>}
    <div class="about-body">
      {Content && <div class="content reveal-content"><Content /></div>}
      <figure class="about-photo photo-portrait reveal-section" style="--reveal-delay: 0.48s;">
        <img src="/Lisa-Portrait.jpeg" alt="Portrait von Lisa Schank" loading="eager" />
      </figure>
    </div>
  </main>
</Layout>

<style>
  .corner-nav {
    position: fixed;
    inset: 0;
    z-index: 30;
    pointer-events: none;
  }

  .corner {
    position: fixed;
    pointer-events: auto;
    color: #111513;
    font-size: clamp(1.55rem, 2.15vw, 2.1rem);
    font-weight: 600;
    line-height: 1;
    text-decoration: none;
    transition: transform 0.25s ease, color 0.25s ease;
  }

  .corner:hover {
    color: #0b3334;
  }

  .top-left {
    top: 10px;
    left: 10px;
  }

  .top-left:hover {
    transform: translateY(-2px);
  }

  .top-right {
    top: 10px;
    right: 10px;
  }

  .top-right:hover {
    transform: translateY(-2px);
  }

  .bottom-left {
    bottom: 10px;
    left: 10px;
  }

  .logo {
    font-size: clamp(1.05rem, 1.8vw, 1.6rem);
    line-height: 0.88;
    transform: rotate(-7deg);
    text-transform: lowercase;
  }

  .logo:hover {
    transform: rotate(-10deg) translateY(-2px);
  }

  .about-gradient {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 22rem 13rem at var(--about-x, 50%) var(--about-y, 50%), rgba(0, 217, 255, 0.42), transparent 62%),
      radial-gradient(ellipse 16rem 24rem at calc(var(--about-x, 50%) + 8%) calc(var(--about-y, 50%) - 6%), rgba(255, 79, 139, 0.31), transparent 64%),
      radial-gradient(ellipse 18rem 10rem at calc(var(--about-x, 50%) - 7%) calc(var(--about-y, 50%) + 9%), rgba(234, 255, 0, 0.26), transparent 66%);
    filter: blur(18px) saturate(1.35);
    opacity: 0.78;
    mix-blend-mode: multiply;
  }

  .page-shell {
    position: relative;
    z-index: 4;
    width: min(980px, calc(100% - 32px));
    margin: 0 auto;
    padding: 22vh 0 18vh;
    isolation: isolate;
  }

  .page-reveal {
    animation: pageReveal 1.05s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .reveal-section,
  .reveal-content > :global(*) {
    opacity: 0;
    transform: translate3d(0, 34px, 0);
    transition:
      opacity 1.15s cubic-bezier(0.16, 1, 0.3, 1),
      transform 1.15s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--reveal-delay, 0s);
    will-change: opacity, filter, transform;
  }

  .reveal-section.is-visible,
  .reveal-content > :global(.is-visible) {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .kicker {
    position: relative;
    z-index: 2;
    margin: 0 0 18px;
    color: #315b56;
    font-weight: 700;
    text-transform: uppercase;
  }

  .name-stage {
    position: relative;
    z-index: 2;
    margin: 0 0 34px;
    width: min(760px, 100%);
    min-height: auto;
    overflow: hidden;
  }

  .name-stage h1 {
    position: relative;
    z-index: 2;
    margin: 0;
    font-size: clamp(3.2rem, 9vw, 7.2rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: 0;
  }

  .headline-marker {
    position: absolute;
    left: -2%;
    top: clamp(3.1rem, 8.6vw, 6.9rem);
    z-index: -1;
    width: 48%;
    height: 0.34em;
    border-radius: 999px;
    background: #00d9ff;
    filter: drop-shadow(0 0 8px rgba(0, 217, 255, 0.34));
    transform-origin: left center;
    animation: drawMarker 0.85s 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  :global(.about-name-fall) {
    position: fixed;
    inset: 0;
    z-index: 2;
    width: 100%;
    height: 100vh;
    display: block;
    touch-action: none;
    cursor: default;
    pointer-events: none;
  }

  .intro {
    position: relative;
    z-index: 2;
    max-width: 700px;
    margin: 0;
    color: #111513;
    font-size: clamp(1.45rem, 2.5vw, 2.25rem);
    line-height: 1.34;
  }

  .content {
    position: relative;
    z-index: 2;
    max-width: 680px;
    margin-top: 48px;
    color: #303530;
    font-size: 1.12rem;
    line-height: 1.75;
  }

  .content > :global(*) {
    margin-top: 0;
    margin-bottom: 1.35em;
  }

  .about-body {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 680px) minmax(220px, 320px);
    gap: clamp(36px, 7vw, 92px);
    align-items: start;
    margin-top: 54px;
  }

  .about-photo {
    margin: 0;
    overflow: hidden;
    border-radius: 8px;
    box-shadow: 0 28px 72px rgba(17, 21, 19, 0.18);
  }

  .about-photo img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .about-photo img {
    object-fit: cover;
    object-position: 50% 44%;
    filter: saturate(0.94) contrast(1.02);
  }

  .photo-portrait {
    position: sticky;
    top: 18vh;
    width: min(100%, 320px);
    aspect-ratio: 4 / 5;
    justify-self: end;
    transform: translateY(18px);
  }

  @media (max-width: 700px) {
    .corner {
      font-size: 1.24rem;
    }

    .page-shell {
      padding-top: 18vh;
      width: min(100% - 28px, 920px);
    }

    .about-body {
      display: block;
      margin-top: 42px;
    }

    .photo-portrait {
      position: relative;
      top: auto;
      width: min(260px, 72vw);
      margin: 34px 0 0 auto;
      transform: none;
    }
  }

  @media (hover: none), (pointer: coarse) {
    .about-gradient {
      background:
        radial-gradient(ellipse 19rem 12rem at 28% 38%, rgba(0, 217, 255, 0.38), transparent 62%),
        radial-gradient(ellipse 15rem 22rem at 68% 44%, rgba(255, 79, 139, 0.28), transparent 64%),
        radial-gradient(ellipse 17rem 10rem at 48% 64%, rgba(234, 255, 0, 0.24), transparent 66%);
      animation: aboutGlow 14s ease-in-out infinite alternate;
      opacity: 0.72;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-section,
    .reveal-content > :global(*) {
      opacity: 1;
      filter: none;
      transform: none;
      transition: none;
    }
  }

  @keyframes pageReveal {
    from {
      opacity: 0;
      transform: scale(1.01);
    }

    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes drawMarker {
    from {
      opacity: 0;
      transform: scaleX(0) skewX(-16deg);
    }

    to {
      opacity: 1;
      transform: scaleX(1) skewX(-10deg);
    }
  }

  @keyframes aboutGlow {
    0% {
      transform: translate3d(-5%, -2%, 0) scale(1);
    }

    50% {
      transform: translate3d(4%, 3%, 0) scale(1.08);
    }

    100% {
      transform: translate3d(1%, -4%, 0) scale(0.98);
    }
  }

</style>

<script>
  function bindAboutGradient() {
    const gradient = document.querySelector('.about-gradient');

    function handlePointerMove(event) {
      if (!gradient || !window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;

      gradient.style.setProperty('--about-x', `${(event.clientX / window.innerWidth) * 100}%`);
      gradient.style.setProperty('--about-y', `${(event.clientY / window.innerHeight) * 100}%`);
    }

    window.removeEventListener('pointermove', window.__aboutGradientMove);
    window.__aboutGradientMove = handlePointerMove;
    window.addEventListener('pointermove', handlePointerMove, { passive: true });
  }

  bindAboutGradient();
  document.addEventListener('astro:page-load', bindAboutGradient);

  function bindAboutTextReveal() {
    const items = [
      ...document.querySelectorAll('.reveal-section'),
      ...document.querySelectorAll('.reveal-content > *'),
    ];

    if (!items.length) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches || !('IntersectionObserver' in window)) {
      items.forEach((item) => item.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      });
    }, {
      rootMargin: '0px 0px -12% 0px',
      threshold: 0.16,
    });

    window.clearTimeout(window.__aboutTextRevealStart);
    window.__aboutTextRevealStart = window.setTimeout(() => {
      items.forEach((item, index) => {
        if (!item.style.getPropertyValue('--reveal-delay')) {
          item.style.setProperty('--reveal-delay', `${Math.min(index * 0.08, 0.42)}s`);
        }
        observer.observe(item);
      });
    }, 720);
  }

  bindAboutTextReveal();
  document.addEventListener('astro:page-load', bindAboutTextReveal);
</script>
