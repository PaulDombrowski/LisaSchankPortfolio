---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Lisa Schank Portfolio', description = 'Portfolio website for Lisa Schank.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
      function forceWhiteBackground() {
        document.documentElement.style.background = '#ffffff';
        document.documentElement.style.backgroundImage = 'none';
        document.body.style.background = '#ffffff';
        document.body.style.backgroundImage = 'none';
      }

      forceWhiteBackground();
      document.addEventListener('astro:page-load', forceWhiteBackground);
      document.addEventListener('astro:after-swap', forceWhiteBackground);
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color: #121513;
    background: #ffffff;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-width: 320px;
    background: #ffffff !important;
  }

  body {
    min-height: 100vh;
    background: #ffffff !important;
    background-image: none !important;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
  }

  ::view-transition-old(root) {
    animation: pageExit 180ms linear both;
    background: #ffffff;
  }

  ::view-transition-new(root) {
    animation: pageEnter 260ms linear both;
    background: #ffffff;
  }

  ::view-transition-group(root) {
    animation-duration: 260ms;
    animation-timing-function: linear;
    background: #ffffff;
  }

  ::view-transition-image-pair(root) {
    isolation: isolate;
    background: #ffffff;
  }

  @keyframes pageExit {
    0% {
      opacity: 1;
    }

    100% {
      opacity: 0;
    }
  }

  @keyframes pageEnter {
    0% {
      opacity: 0;
    }

    100% {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(root),
    ::view-transition-new(root),
    ::view-transition-group(root) {
      animation-duration: 1ms;
    }
  }

  @supports not (view-transition-name: root) {
    @keyframes pageExit {
      to {
        opacity: 0;
      }
    }

    @keyframes pageEnter {
      from {
        opacity: 0;
      }
    }
  }
</style>
